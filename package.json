{
  "name": "dawnlike-atlas",
  "version": "1.0.0",
  "type": "module",
  "description": "Semantic Mega-Atlas for the DawnLike tileset with 16-way autotiling, AI tagging, and a manifest-driven roguelike toolkit (generators + autotile renderer + Phaser scenes).",
  "main": "react/index.js",
  "exports": {
    ".": {
      "types": "./react/index.d.ts",
      "import": "./react/index.js",
      "default": "./react/index.js"
    },
    "./roguelike": "./roguelike/index.js",
    "./roguelike/generators": "./roguelike/generators.js",
    "./roguelike/autotile":   "./roguelike/autotile.js",
    "./roguelike/phaser":     "./roguelike/phaser.js",
    "./roguelike/save":       "./roguelike/save.js",
    "./atlas/DawnlikeAtlas.json": "./atlas/DawnlikeAtlas.json",
    "./atlas/DawnlikeAtlas0.png": "./atlas/DawnlikeAtlas0.png",
    "./atlas/DawnlikeAtlas1.png": "./atlas/DawnlikeAtlas1.png",
    "./package.json": "./package.json"
  },
  "files": [
    "react",
    "roguelike",
    "src/phaser",
    "src/utils/autotile.js",
    "src/utils/paths.js",
    "atlas/DawnlikeAtlas.json",
    "atlas/DawnlikeAtlas0.png",
    "atlas/DawnlikeAtlas1.png",
    "README.md"
  ],
  "scripts": {
    "dev": "bun run storybook",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "phaser": "4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "rot-js": "^2.2.1"
  },
  "license": "CC-BY-4.0",
  "private": true,
  "devDependencies": {
    "@chromatic-com/storybook": "^5.2.1",
    "@storybook/addon-a11y": "8.6.14",
    "@storybook/addon-docs": "8.6.14",
    "@storybook/addon-essentials": "8.6.14",
    "@storybook/addon-interactions": "8.6.14",
    "@storybook/addon-links": "8.6.14",
    "@storybook/addon-mcp": "^0.6.0",
    "@storybook/addon-vitest": "^10.4.0",
    "@storybook/blocks": "8.6.14",
    "@storybook/react": "8.6.14",
    "@storybook/react-vite": "8.6.14",
    "@storybook/test": "8.6.14",
    "@types/bun": "latest",
    "@vitest/browser-playwright": "^4.1.6",
    "@vitest/coverage-v8": "^4.1.6",
    "playwright": "^1.60.0",
    "prop-types": "^15.8.1",
    "storybook": "8.6.14",
    "vite": "^5",
    "vitest": "^4.1.6"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
