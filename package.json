{
  "name": "dawnlike-atlas",
  "version": "0.1.0",
  "type": "module",
  "description": "Semantic Mega-Atlas for the DawnLike 16x16 tileset: bin-packed sprite sheets, semantic name lookup, AI-generated tags, and 16-way autotile resolvers.",
  "main": "react/index.js",
  "exports": {
    ".": {
      "types": "./react/index.d.ts",
      "import": "./react/index.js",
      "default": "./react/index.js"
    },
    "./autotile": "./src/utils/autotile.js",
    "./atlas/DawnlikeAtlas.json": "./atlas/DawnlikeAtlas.json",
    "./atlas/DawnlikeAtlas0.png": "./atlas/DawnlikeAtlas0.png",
    "./atlas/DawnlikeAtlas1.png": "./atlas/DawnlikeAtlas1.png",
    "./package.json": "./package.json"
  },
  "files": [
    "react",
    "src/utils/autotile.js",
    "src/utils/paths.js",
    "atlas/DawnlikeAtlas.json",
    "atlas/DawnlikeAtlas0.png",
    "atlas/DawnlikeAtlas1.png",
    "README.md"
  ],
  "scripts": {
    "dev": "bun run storybook",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "tag-animated": "node scripts/tag-animated.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lucas-stanford/dawnlike-atlas.git"
  },
  "homepage": "https://lucas-stanford.github.io/dawnlike-atlas/",
  "bugs": {
    "url": "https://github.com/lucas-stanford/dawnlike-atlas/issues"
  },
  "keywords": [
    "dawnlike",
    "atlas",
    "tileset",
    "sprites",
    "roguelike",
    "pixel-art",
    "autotile",
    "react"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "license": "CC-BY-4.0",
  "devDependencies": {
    "@chromatic-com/storybook": "^5.2.1",
    "@storybook/addon-a11y": "8.6.14",
    "@storybook/addon-docs": "8.6.14",
    "@storybook/addon-essentials": "8.6.14",
    "@storybook/addon-interactions": "8.6.14",
    "@storybook/addon-links": "8.6.14",
    "@storybook/addon-mcp": "^0.6.0",
    "@storybook/addon-vitest": "^10.4.0",
    "@storybook/blocks": "8.6.14",
    "@storybook/react": "8.6.14",
    "@storybook/react-vite": "8.6.14",
    "@storybook/test": "8.6.14",
    "@types/bun": "latest",
    "@vitest/browser-playwright": "^4.1.6",
    "@vitest/coverage-v8": "^4.1.6",
    "phaser": "4",
    "playwright": "^1.60.0",
    "pngjs": "^7.0.0",
    "prop-types": "^15.8.1",
    "rot-js": "^2.2.1",
    "storybook": "8.6.14",
    "vite": "^5",
    "vitest": "^4.1.6"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
